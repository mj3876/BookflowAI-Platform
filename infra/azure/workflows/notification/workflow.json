{
  "definition": {
    "$schema": "https://schema.management.azure.com/providers/Microsoft.Logic/schemas/2016-06-01/workflowdefinition.json#",
    "contentVersion": "1.0.0.0",
    "description": "EKS notification-svc로부터 HTTP POST를 받아 event_type에 따라 ACS Email 알림을 발송한다. 수신자 목록은 호출자(notification-svc)가 결정해 body.recipients로 전달한다. 내부 수치 데이터 미포함, 역할별 대시보드 링크만 포함.",
    "parameters": {
      "ACS_EMAIL_URI":  { "type": "string", "defaultValue": "" },
      "LA_IDENTITY_ID": { "type": "string", "defaultValue": "" },
      "ACS_SENDER":     { "type": "string", "defaultValue": "" },
      "DASHBOARD_URL":  { "type": "string", "defaultValue": "" }
    },
    "triggers": {
      "manual": {
        "description": "notification-svc가 SAS URL로 POST 호출. body: { event_type, severity, payload, recipients[] }",
        "type": "Request",
        "kind": "Http",
        "inputs": {
          "schema": {
            "type": "object",
            "properties": {
              "event_type": { "type": "string" },
              "severity":   { "type": "string" },
              "payload":    { "type": "object" },
              "recipients": { "type": "array" }
            },
            "required": ["event_type", "severity", "payload", "recipients"]
          }
        }
      }
    },
    "actions": {
      "Switch_EventType": {
        "description": "event_type 값으로 분기. 미구현 타입은 default(no-op)로 처리된다.",
        "type": "Switch",
        "expression": "@triggerBody()?['event_type']",
        "cases": {
          "DailyPlanFinalized": {
            "case": "DailyPlanFinalized",
            "actions": {
              "Email_DailyPlanFinalized": {
                "description": "패턴 2 — 의사결정 완료 알림. 수신자: 본사+물류센터+지점. 역할별 WhTransfer 분석 뷰 링크 포함.",
                "type": "Http",
                "operationOptions": "DisableAsyncPattern",
                "inputs": {
                  "method": "POST",
                  "uri": "@parameters('ACS_EMAIL_URI')",
                  "authentication": {
                    "type": "ManagedServiceIdentity",
                    "identity": "@parameters('LA_IDENTITY_ID')",
                    "audience": "https://communication.azure.com"
                  },
                  "body": {
                    "senderAddress": "@parameters('ACS_SENDER')",
                    "recipients": { "to": "@triggerBody()?['recipients']" },
                    "content": {
                      "subject": "[최종확정] 의사결정 완료 · 운송 시작 가능",
                      "html": "<p>당일 모든 의사결정이 완료되었습니다. 운송을 시작할 수 있습니다.</p><h4>WhTransfer 분석 뷰</h4><ul><li><a href=\"@{parameters('DASHBOARD_URL')}/wh-transfer?role=hq\">본사 담당자 접속</a></li><li><a href=\"@{parameters('DASHBOARD_URL')}/wh-transfer?role=warehouse\">물류센터 담당자 접속</a></li><li><a href=\"@{parameters('DASHBOARD_URL')}/wh-transfer?role=branch\">지점 담당자 접속</a></li></ul>"
                    },
                    "importance": "normal"
                  }
                }
              }
            }
          },
          "SpikeUrgent": {
            "case": "SpikeUrgent",
            "actions": {
              "Email_SpikeUrgent": {
                "description": "패턴 3 — SNS 화제 도서 감지 · 매출 폭증 가능성 긴급 알림. 수신자: 본사+물류센터. 본사 강제 승인 링크 + WhTransfer 분석 뷰 포함.",
                "type": "Http",
                "operationOptions": "DisableAsyncPattern",
                "inputs": {
                  "method": "POST",
                  "uri": "@parameters('ACS_EMAIL_URI')",
                  "authentication": {
                    "type": "ManagedServiceIdentity",
                    "identity": "@parameters('LA_IDENTITY_ID')",
                    "audience": "https://communication.azure.com"
                  },
                  "body": {
                    "senderAddress": "@parameters('ACS_SENDER')",
                    "recipients": { "to": "@triggerBody()?['recipients']" },
                    "content": {
                      "subject": "[긴급] SNS 화제 도서 감지 · 매출 폭증 가능성",
                      "html": "<p>SNS 화제 도서가 감지되었습니다. 24시간 내 매출 폭증 가능성이 있습니다.</p><h4>즉시 조치</h4><ul><li><a href=\"@{parameters('DASHBOARD_URL')}/decision/force-approve\">본사 강제 승인</a></li></ul><h4>WhTransfer 분석 뷰</h4><ul><li><a href=\"@{parameters('DASHBOARD_URL')}/wh-transfer?role=hq\">본사 담당자 접속</a></li><li><a href=\"@{parameters('DASHBOARD_URL')}/wh-transfer?role=warehouse\">물류센터 담당자 접속</a></li></ul>"
                    },
                    "importance": "high"
                  }
                }
              }
            }
          },
          "NegotiationDelay": {
            "case": "NegotiationDelay",
            "actions": {
              "Email_NegotiationDelay": {
                "description": "협의 지연 알림. 수신자: 본사+물류센터. 본사 강제 승인 링크 + WhTransfer 분석 뷰 포함.",
                "type": "Http",
                "operationOptions": "DisableAsyncPattern",
                "inputs": {
                  "method": "POST",
                  "uri": "@parameters('ACS_EMAIL_URI')",
                  "authentication": {
                    "type": "ManagedServiceIdentity",
                    "identity": "@parameters('LA_IDENTITY_ID')",
                    "audience": "https://communication.azure.com"
                  },
                  "body": {
                    "senderAddress": "@parameters('ACS_SENDER')",
                    "recipients": { "to": "@triggerBody()?['recipients']" },
                    "content": {
                      "subject": "[협의지연] 처리 대기 항목 확인 필요",
                      "html": "<p>협의가 지연되고 있습니다. 확인 및 조치가 필요합니다.</p><h4>즉시 조치</h4><ul><li><a href=\"@{parameters('DASHBOARD_URL')}/decision/force-approve\">본사 강제 승인</a></li></ul><h4>WhTransfer 분석 뷰</h4><ul><li><a href=\"@{parameters('DASHBOARD_URL')}/wh-transfer?role=hq\">본사 담당자 접속</a></li><li><a href=\"@{parameters('DASHBOARD_URL')}/wh-transfer?role=warehouse\">물류센터 담당자 접속</a></li></ul>"
                    },
                    "importance": "high"
                  }
                }
              }
            }
          }
        },
        "default": { "actions": {} }
      },
      "Response": {
        "description": "Switch 결과(성공/실패/스킵/타임아웃 무관)로 200 {result:ok} 반환. notification-svc는 이 응답으로 발송 성공 여부를 판단한다.",
        "type": "Response",
        "runAfter": {
          "Switch_EventType": ["Succeeded", "Failed", "Skipped", "TimedOut"]
        },
        "inputs": {
          "statusCode": 200,
          "body": { "result": "ok" }
        }
      }
    }
  },
  "kind": "Stateful"
}
