{
  "definition": {
    "$schema": "https://schema.management.azure.com/providers/Microsoft.Logic/schemas/2016-06-01/workflowdefinition.json#",
    "contentVersion": "1.0.0.0",
    "description": "긴급 이벤트 알림 전용. SpikeUrgent(SNS 화제 도서), NegotiationDelay(협의 지연), DailyPlanFinalized(의사결정 완료·운송 시작) 3종. notification-svc가 HTTP POST로 호출.",
    "parameters": {
      "ACS_EMAIL_URI":  { "type": "string", "defaultValue": "" },
      "LA_IDENTITY_ID": { "type": "string", "defaultValue": "" },
      "ACS_SENDER":     { "type": "string", "defaultValue": "" },
      "DASHBOARD_URL":  { "type": "string", "defaultValue": "" }
    },
    "triggers": {
      "manual": {
        "description": "notification-svc가 SAS URL로 POST 호출. body: { event_type, severity, payload, recipients[] }",
        "type": "Request",
        "kind": "Http",
        "inputs": {
          "schema": {
            "type": "object",
            "properties": {
              "event_type": { "type": "string" },
              "severity":   { "type": "string" },
              "payload":    { "type": "object" },
              "recipients": { "type": "array" }
            },
            "required": ["event_type", "severity", "payload", "recipients"]
          }
        }
      }
    },
    "actions": {
      "Switch_EventType": {
        "description": "event_type 값으로 분기. 미구현 타입은 default(no-op)로 처리된다.",
        "type": "Switch",
        "expression": "@triggerBody()?['event_type']",
        "cases": {
          "DailyPlanFinalized": {
            "case": "DailyPlanFinalized",
            "actions": {
              "Email_DailyPlanFinalized": {
                "description": "의사결정 완료 알림. 수신자: 본사+물류센터+지점.",
                "type": "Http",
                "operationOptions": "DisableAsyncPattern",
                "inputs": {
                  "method": "POST",
                  "uri": "@parameters('ACS_EMAIL_URI')",
                  "authentication": {
                    "type": "ManagedServiceIdentity",
                    "identity": "@parameters('LA_IDENTITY_ID')",
                    "audience": "https://communication.azure.com"
                  },
                  "body": {
                    "senderAddress": "@parameters('ACS_SENDER')",
                    "recipients": { "to": "@triggerBody()?['recipients']" },
                    "content": {
                      "subject": "[최종확정] 의사결정 완료 · 운송 시작 가능",
                      "html": "<p>당일 모든 의사결정이 완료되었습니다. 운송을 시작할 수 있습니다.</p><ul><li><a href=\"@{parameters('DASHBOARD_URL')}\">BookFlow 대시보드 바로가기</a></li></ul>"
                    },
                    "importance": "normal"
                  }
                }
              }
            }
          },
          "SpikeUrgent": {
            "case": "SpikeUrgent",
            "actions": {
              "Email_SpikeUrgent": {
                "description": "SNS 화제 도서 감지 · 매출 폭증 가능성 긴급 알림. 수신자: 본사+물류센터.",
                "type": "Http",
                "operationOptions": "DisableAsyncPattern",
                "inputs": {
                  "method": "POST",
                  "uri": "@parameters('ACS_EMAIL_URI')",
                  "authentication": {
                    "type": "ManagedServiceIdentity",
                    "identity": "@parameters('LA_IDENTITY_ID')",
                    "audience": "https://communication.azure.com"
                  },
                  "body": {
                    "senderAddress": "@parameters('ACS_SENDER')",
                    "recipients": { "to": "@triggerBody()?['recipients']" },
                    "content": {
                      "subject": "[긴급] SNS 화제 도서 감지 · 매출 폭증 가능성",
                      "html": "<p>SNS 화제 도서가 감지되었습니다. 24시간 내 매출 폭증 가능성이 있습니다.</p><ul><li><a href=\"@{parameters('DASHBOARD_URL')}\">BookFlow 대시보드 바로가기</a></li></ul>"
                    },
                    "importance": "high"
                  }
                }
              }
            }
          },
          "NegotiationDelay": {
            "case": "NegotiationDelay",
            "actions": {
              "Email_NegotiationDelay": {
                "description": "협의 지연 알림. 수신자: 본사+물류센터.",
                "type": "Http",
                "operationOptions": "DisableAsyncPattern",
                "inputs": {
                  "method": "POST",
                  "uri": "@parameters('ACS_EMAIL_URI')",
                  "authentication": {
                    "type": "ManagedServiceIdentity",
                    "identity": "@parameters('LA_IDENTITY_ID')",
                    "audience": "https://communication.azure.com"
                  },
                  "body": {
                    "senderAddress": "@parameters('ACS_SENDER')",
                    "recipients": { "to": "@triggerBody()?['recipients']" },
                    "content": {
                      "subject": "[협의지연] 처리 대기 항목 확인 필요",
                      "html": "<p>협의가 지연되고 있습니다. 확인 및 조치가 필요합니다.</p><ul><li><a href=\"@{parameters('DASHBOARD_URL')}\">BookFlow 대시보드 바로가기</a></li></ul>"
                    },
                    "importance": "high"
                  }
                }
              }
            }
          }
        },
        "default": { "actions": {} }
      },
      "Response": {
        "description": "Switch 결과(성공/실패/스킵/타임아웃 무관)로 200 {result:ok} 반환.",
        "type": "Response",
        "runAfter": {
          "Switch_EventType": ["Succeeded", "Failed", "Skipped", "TimedOut"]
        },
        "inputs": {
          "statusCode": 200,
          "body": { "result": "ok" }
        }
      }
    }
  },
  "kind": "Stateful"
}
