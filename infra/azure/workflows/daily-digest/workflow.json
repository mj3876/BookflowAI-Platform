{
  "definition": {
    "$schema": "https://schema.management.azure.com/providers/Microsoft.Logic/schemas/2016-06-01/workflowdefinition.json#",
    "contentVersion": "1.0.0.0",
    "description": "매일 09:00 KST(UTC 00:00) DIGEST_RECIPIENTS에 역할별 대시보드 링크 브리핑 메일을 발송한다. 내부 수치 데이터(재고·매출·건수)는 포함하지 않는다.",
    "parameters": {
      "ACS_EMAIL_URI":     { "type": "string", "defaultValue": "" },
      "LA_IDENTITY_ID":    { "type": "string", "defaultValue": "" },
      "ACS_SENDER":        { "type": "string", "defaultValue": "" },
      "DIGEST_RECIPIENTS": { "type": "string", "defaultValue": "[]" },
      "DASHBOARD_URL":     { "type": "string", "defaultValue": "" }
    },
    "triggers": {
      "Recurrence_0900KST": {
        "description": "매일 UTC 00:00 (KST 09:00) 에 실행",
        "type": "Recurrence",
        "recurrence": {
          "frequency": "Day",
          "interval": 1,
          "schedule": { "hours": ["0"], "minutes": [0] },
          "timeZone": "UTC"
        }
      }
    },
    "actions": {
      "Send_DailyDigest": {
        "description": "역할별 WhTransfer 분석 뷰 링크와 본사 강제 승인 링크만 포함한 일일 브리핑 메일 발송. 내부 API 미호출.",
        "type": "Http",
        "operationOptions": "DisableAsyncPattern",
        "inputs": {
          "method": "POST",
          "uri": "@parameters('ACS_EMAIL_URI')",
          "authentication": {
            "type": "ManagedServiceIdentity",
            "identity": "@parameters('LA_IDENTITY_ID')",
            "audience": "https://communication.azure.com"
          },
          "body": {
            "senderAddress": "@parameters('ACS_SENDER')",
            "recipients": { "to": "@json(parameters('DIGEST_RECIPIENTS'))" },
            "content": {
              "subject": "[일일브리핑] BookFlow @{formatDateTime(utcNow(), 'yyyy-MM-dd')}",
              "html": "<h2>BookFlow 일일 업무 브리핑</h2><p>@{formatDateTime(utcNow(), 'yyyy-MM-dd')} 오늘의 운영 현황을 아래 링크에서 확인하세요.</p><h4>WhTransfer 분석 뷰</h4><ul><li><a href=\"@{parameters('DASHBOARD_URL')}/wh-transfer?role=hq\">본사 담당자</a></li><li><a href=\"@{parameters('DASHBOARD_URL')}/wh-transfer?role=warehouse\">물류센터 담당자</a></li><li><a href=\"@{parameters('DASHBOARD_URL')}/wh-transfer?role=branch\">지점 담당자</a></li></ul><h4>본사 강제 승인</h4><ul><li><a href=\"@{parameters('DASHBOARD_URL')}/decision/force-approve\">강제 승인 바로가기</a></li></ul>"
            },
            "importance": "normal"
          }
        }
      }
    }
  },
  "kind": "Stateful"
}
